{
  "name": "cortex-tv",
  "private": true,
  "version": "1.0.0-beta.1",
  "description": "Cortex TV – 3D Interactive Globe IPTV Explorer",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.electron.json && vite build",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "build:mobile": "npm run build && npx cap sync android",
    "preview": "vite preview",
    "electron:build": "npm run build && electron-builder",
    "electron:dev": "vite"
  },
  "build": {
    "appId": "com.cortextv.app",
    "productName": "Cortex TV",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/vite.svg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "gh-pages": "^6.3.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "hls.js": "^1.6.15",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-globe.gl": "^2.37.0",
    "react-player": "^3.4.0",
    "react-virtuoso": "^4.18.1",
    "three": "^0.183.1",
    "zustand": "^5.0.11"
  }
}
